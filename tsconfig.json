{
  "compilerOptions": {
    "target": "ES2025",
    "module": "ESNext",
    "lib": ["ES2025", "DOM"],
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowArbitraryExtensions": true,
    "types": ["vitest/globals"]
  },
  "include": ["src/js/**/*.ts", "e2e/**/*.ts", "*.config.ts"]
}
