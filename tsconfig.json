{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["src/js/**/*.ts", "e2e/**/*.ts", "*.config.ts"],
  "exclude": ["src/js/**/*.test.ts"]
}
